# Required for the normal Euler View HTTP streaming path.
EULER_VIEW_BASE_URL=https://view.example.com
EULER_VIEW_API_TOKEN=replace-me

# Prefer an explicit stream attachment token when Euler View launches the job.
EULER_VIEW_STREAM_ATTACH_TOKEN=replace-me

# If no stream attach token is available, set the model id for SLURM fallback
# matching. This is not needed when EULER_VIEW_STREAM_ATTACH_TOKEN is set.
# EULER_VIEW_MODEL_ID=42

# Optional stream settings.
# EULER_VIEW_DATASOURCE_ID=7
# EULER_TRAIN_TEST_OUTPUT_DIR=$SCRATCH/euler-train-stream-test
# EULER_TRAIN_TEST_EPOCHS=2
# EULER_TRAIN_TEST_STEPS=8
# EULER_TRAIN_TEST_CHECK_HANDSHAKE=1
